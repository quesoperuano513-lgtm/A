
[Items]

	[Items."Eye Of Structure"]
		#If set to 'True' eye of structure will be consume item on release
		"Consume Item On Release" = false
		#Set item cool down time after player on use (in seconds)
		#Range: 0.0 ~ 60.0
		"Set Item Cool Down Time" = 4.0

	[Items.Weapon]

		[Items.Weapon."Doombolt Battleaxe"]
			#Set item cool down time after player on use (in seconds)
			#Range: 0.0 ~ 60.0
			"Set Item Cool Down Time" = 3.0
			#Set tool attack damage(Restart required)
			#Range: 0.0 ~ 3.4028234663852886E38
			"Attack Damage" = 15.0
			#Set tool attack speed(Restart required)
			#Range: 0.0 ~ 3.4028234663852886E38
			"Attack Speed" = 0.9

			[Items.Weapon."Doombolt Battleaxe".Surge]
				#Set this entity attack damage
				#Range: 1.0 ~ 3.4028234663852886E38
				"Attack Damage" = 7.5

		[Items.Weapon."Annihilator Sawblade"]
			#Set tool attack damage(Restart required)
			#Range: 0.0 ~ 3.4028234663852886E38
			"Attack Damage" = 10.0
			#Set tool attack speed(Restart required)
			#Range: 0.0 ~ 3.4028234663852886E38
			"Attack Speed" = 1.6
			#Set the percentage of damage increase per stack
			#Range: 1.0 ~ 10.0
			"Set Damage Bonus Per Stack" = 5.0
			#Set the maximum number of stacks for the damage buff
			#Range: 0 ~ 10
			"Set Max Buff Stacks" = 5

		[Items.Weapon."Guardian Core"]
			#Set the maximum shooting distance for players
			#Range: 1.0 ~ 64.0
			"Set Attack Radius" = 16.0
			#If set to 'False' disable block destruction by players
			"Enable Destroy Block" = false
			#Set this entity attack damage
			#Range: 1.0 ~ 3.4028234663852886E38
			"Attack Damage" = 5.0

		[Items.Weapon."Buster Gauntlet"]
			#Range: 1.0 ~ 3.4028234663852886E38
			"Set Projectile Damage" = 10.0
			#Set Grenade explosion radius
			#Range: 1.0 ~ 5.0
			"Set Attack Radius" = 2.5
			#Set item cool down time after player on use (in seconds)
			#Range: 0.0 ~ 60.0
			"Set Item Cool Down Time" = 4.0
			#Set tool attack damage(Restart required)
			#Range: 0.0 ~ 3.4028234663852886E38
			"Attack Damage" = 8.0
			#Set tool attack speed(Restart required)
			#Range: 0.0 ~ 3.4028234663852886E38
			"Attack Speed" = 1.6

	[Items.Accessories]

		[Items.Accessories."Summoning Soul Necklace"]
			#Set maximum amount of damage a player can take while holding this item
			#Range: 1.0 ~ 3.4028234663852886E38
			"Set Maximum Cumulative Damage Taken" = 50.0
			#Set item cool down time after player on use (in seconds)
			#Range: 0.0 ~ 60.0
			"Set Item Cool Down Time" = 20.0

[Entities]

	[Entities."Falling Block"]
		#If set to 'False' disable falling block spawn
		"Enable Falling Block Spawn" = true
		#Set the maximum range for downward block detection to determine the Y-axis position where the entity spawns
